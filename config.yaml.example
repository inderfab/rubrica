database:
  path: rubrica.db

server:
  port: 8001

# Phase 2: CardDAV-Sync nach Radicale (App -> Radicale -> Apple Kontakte, nie umgekehrt).
# Immer aktiv, sobald base_url gesetzt ist (kein separater An/Aus-Schalter mehr - ohne
# Sync ist die App fuer den produktiven Einsatz nutzlos, ein versehentlich ausgeschalteter
# Schalter hat bereits zu Verwirrung gefuehrt, siehe docs/konzept.md).
radicale:
  base_url: https://127.0.0.1:8443
  # __RUBRICA_USER__ wird beim Erststart durch den tatsaechlichen macOS-Benutzernamen ersetzt
  # (siehe Contents/MacOS/Rubrica Server im gepackten .app-Bundle bzw. scripts/dev.sh).
  addressbook_path: /__RUBRICA_USER__/kontakte/
  username: __RUBRICA_USER__
  password: ""

# Phase 4: Archivio-Anbindung - liest die von Archivio gefuehrte Signatur-DB
# (Tabelle signatur_quelle: Absender, Postfach, voller Mailtext, Status) und
# erzeugt daraus Kontaktvorschlaege in der Review-Queue. Deaktiviert, solange
# signatur_db_path leer ist. Nie automatisches Anlegen von Kontakten - landet
# immer erst als Vorschlag (siehe docs/konzept.md Abschnitt 5.1/9).
archivio:
  signatur_db_path: ""
  min_mails: 2

# Automatisches Backup: nach jeder aendernden Anfrage wird ein Snapshot der
# Datenbank an diesen Ordner geschrieben (per sqlite3-Backup-API, konsistent
# auch bei laufendem Schreibzugriff). Deaktiviert, solange pfad leer ist.
backup:
  pfad: ""
